# Ollama — no OPENAI_API_KEY required
# For local Ollama: leave LLAMA_API_TOKEN empty or set to "ollama"
LLAMA_API_TOKEN=ollama

# Ollama API base URL (default: local)
LLAMA_API_BASE=http://localhost:11434/v1

# Model: Ollama model name (prefix with "ollama/")
# Llama 3:
#   LLAMA_MODEL=ollama/llama3:8b
# DeepSeek:
#   LLAMA_MODEL=ollama/deepseek-r1
#   LLAMA_MODEL=ollama/deepseek-llm
LLAMA_MODEL=ollama/llama3:8b
